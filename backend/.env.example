# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Configuration
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority

# JWT Configuration
# SECURITY: Generate a strong random secret for production
# Use: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# DO NOT use simple strings like "mysecret" or "secret123"
JWT_SECRET=your_jwt_secret_key_here

# JWT token expiration time (e.g., 7d, 24h, 30m)
# Recommended: 7d for production, shorter for high-security applications
JWT_EXPIRE=7d

# Client URL (for CORS)
# In production, set this to your actual frontend domain
CLIENT_URL=http://localhost:3000

# ====================
# SECURITY BEST PRACTICES:
# ====================
# 1. NEVER commit the actual .env file to version control
# 2. Use strong, randomly generated secrets for JWT_SECRET (64+ characters)
# 3. Keep JWT_EXPIRE reasonable (7d recommended, max 30d)
# 4. Set CLIENT_URL to your actual frontend URL in production
# 5. Regularly rotate your JWT_SECRET in production
# 6. Use environment-specific .env files (.env.development, .env.production)

